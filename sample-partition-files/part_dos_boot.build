# The DOS partition only needs to be large enough to hold the IFS
# Set the DOS partition (t12) to 200MB in this example
[num_sectors=409600]

config.txt = {
arm_64bit=1
cmdline=cmdline.txt
device_tree=bcm2711-rpi-4-b.dtb
max_framebuffers=2
enable_uart=1
kernel=qnx_sdp.ifs
}

cmdline.txt = {
verbose root=/dev/sd0t179 rootfstype=qnx6fs
}

qnx_sdp.ifs=ifs-rpi4-hyp.bin
bcm2711-rpi-4-b.dtb=bcm2711-rpi-4-b.dtb
start4.elf=start4.elf
fixup4.dat=fixup4.dat
overlays=overlays
